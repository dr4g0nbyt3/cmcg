{
  "cmcg_version": "1.0",
  "meta": {
    "name": "CMCG Phase 2 Demo",
    "resolution": [1920, 1080],
    "fps": 30,
    "duration": 15.0
  },
  "variables": {
    "$adImage": null,
    "$logoUrl": null,
    "$headline": "Dynamic Video Templates",
    "$subtitle": "Swap any slot via URL, variable, or API — no re-encoding needed."
  },
  "base_video": "/base/background.mp4",
  "slots": [
    {
      "id": "slot_logo",
      "type": "image",
      "start": 0,
      "duration": 15,
      "position": { "x": 60, "y": 40, "w": 120, "h": 120 },
      "source": {
        "variable": "$logoUrl",
        "fallback": "/assets/placeholder-logo.svg"
      },
      "cache": "session"
    },
    {
      "id": "slot_headline",
      "type": "text",
      "start": 0.5,
      "duration": 14.5,
      "position": { "x": 60, "y": 200, "w": 1000, "h": 120 },
      "source": {},
      "text": {
        "content": "$headline",
        "fontSize": 64,
        "fontWeight": "700",
        "color": "#ffffff",
        "fontFamily": "DM Sans, system-ui, sans-serif",
        "align": "left",
        "lineHeight": 76
      }
    },
    {
      "id": "slot_subtitle",
      "type": "text",
      "start": 1.5,
      "duration": 13.5,
      "position": { "x": 60, "y": 330, "w": 800, "h": 80 },
      "source": {},
      "text": {
        "content": "$subtitle",
        "fontSize": 24,
        "fontWeight": "300",
        "color": "#7b7f9e",
        "fontFamily": "DM Sans, system-ui, sans-serif",
        "align": "left",
        "lineHeight": 36
      }
    },
    {
      "id": "slot_ad_banner",
      "type": "image",
      "start": 2.0,
      "duration": 11.0,
      "position": { "x": 40, "y": 820, "w": 1840, "h": 200 },
      "source": {
        "variable": "$adImage",
        "remote": "https://picsum.photos/seed/cmcg-ad/1840/200",
        "fallback": "/assets/placeholder-banner.svg"
      },
      "cache": "session",
      "fetchTimeout": 3000
    },
    {
      "id": "slot_cta_badge",
      "type": "text",
      "start": 3.0,
      "duration": 10.0,
      "position": { "x": 60, "y": 440, "w": 260, "h": 44 },
      "source": {},
      "text": {
        "content": "github.com/dr4g0nbyt3/cmcg",
        "fontSize": 16,
        "fontWeight": "500",
        "color": "#4fffb0",
        "fontFamily": "IBM Plex Mono, monospace",
        "background": "rgba(79,255,176,0.08)",
        "padding": 12
      }
    }
  ]
}
