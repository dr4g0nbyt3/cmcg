{
  "cmcg_version": "1.0",
  "meta": {
    "name": "CMCG Proof of Concept",
    "resolution": [1920, 1080],
    "fps": 30,
    "duration": 15.0
  },
  "variables": {
    "$adImage": null,
    "$logoUrl": null
  },
  "base_video": "/base/background.mp4",
  "slots": [
    {
      "id": "slot_ad_banner",
      "type": "image",
      "start": 2.0,
      "duration": 10.0,
      "position": { "x": 40, "y": 820, "w": 1840, "h": 200 },
      "source": {
        "variable": "$adImage",
        "remote": "https://picsum.photos/seed/cmcg-ad/1840/200",
        "fallback": "/assets/placeholder-banner.svg"
      },
      "cache": "session",
      "fetchTimeout": 3000
    },
    {
      "id": "slot_logo",
      "type": "image",
      "start": 0,
      "duration": 15,
      "position": { "x": 60, "y": 40, "w": 180, "h": 180 },
      "source": {
        "variable": "$logoUrl",
        "fallback": "/assets/placeholder-logo.svg"
      },
      "cache": "session"
    }
  ]
}
